# Copy file ini, rename jadi .env untuk local development
# Di Vercel, set variable ini di: Settings → Environment Variables

# Wajib: Connection string dari MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Wajib: Secret key untuk JWT token (buat string random panjang)
JWT_SECRET=ganti_dengan_string_random_yang_panjang_dan_aman
